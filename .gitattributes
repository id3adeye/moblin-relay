# Normalize text to LF in the repo; check out native on each platform.
# Without this, editing from Windows over WSL re-flags unchanged files as modified.
* text=auto eol=lf

# Never run binary assets through line-ending conversion.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
*.mp4 binary
*.webm binary
